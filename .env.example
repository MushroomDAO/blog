# ============================================
# 多用户博客发布系统配置
# 复制此文件为 .env 并填入你的实际配置
# ============================================

# ---------------- 用户选择 ----------------
# 设置当前使用的用户配置
# 对应 config/users/{BLOG_USER}.js 文件
BLOG_USER=mushroom

# ---------------- Blog 配置 (M1) ----------------
# Cloudflare Pages 项目名
BLOG_PROJECT_NAME=blog-mushroom

# 自定义域名（可选）
BLOG_DOMAIN=blog.mushroom.cv

# ---------------- 微信公众号配置 (M2) ----------------
# 从 https://mp.weixin.qq.com -> 设置与开发 -> 基本配置 获取
WECHAT_APP_ID=wx7015e9b1ed77dd66
WECHAT_APP_SECRET=your_app_secret_here

# 公众号原始ID (gh_xxx)
# 从公众号设置页面获取
WECHAT_MP_ID=gh_ba9082b3a7aa

# 默认作者名（用于公众号文章）
WECHAT_DEFAULT_AUTHOR=Mycelium

# ---------------- 小红书配置 (M3) ----------------
# MCP 服务地址（需要在 Mac Mini 上部署 xiaohongshu-mcp）
# 参考: https://github.com/xpzouying/xiaohongshu-mcp
XHS_MCP_URL=http://localhost:3456

# 小红书账号 Cookie（通过 MCP 扫码登录后自动获取）
# 不需要手动设置，MCP 服务会管理

# ---------------- 评论系统配置 (Giscus) ----------------
# Giscus 基于 GitHub Discussions 的评论系统
# 配置步骤：
# 1. 确保仓库已开启 Discussions 功能 (Settings -> Features -> Discussions)
# 2. 访问 https://giscus.app/zh-CN 获取配置
# 3. 将以下配置填入 .env 文件

# GitHub 仓库（格式: owner/repo）
GISCUS_REPO=MushroomDAO/blog

# 仓库 ID（从 giscus.app 获取）
GISCUS_REPO_ID=your_repo_id_here

# 讨论分类
GISCUS_CATEGORY=General

# 分类 ID（从 giscus.app 获取）
GISCUS_CATEGORY_ID=your_category_id_here

# ---------------- 可选配置 ----------------
# 日志级别: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# 输出目录
OUTPUT_DIR=./output

# 临时文件目录
TEMP_DIR=/tmp/blog-pipeline

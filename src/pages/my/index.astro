---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

const posts = (await getCollection('my')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categoryIcons: Record<string, string> = {
	'Hardware': '🔧',
	'Research': '🔬',
	'Launch': '🚀',
	'Lessons': '📚',
	'Thought': '💭',
};
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title="My — Jason's Notes" description="Jason 的亲历记录：硬件折腾、AI 研究、产品发布、经验与教训" />
		<style>
			:root {
				--accent-cyan: 0, 212, 255;
				--accent-amber: 251, 191, 36;
				--accent-orange: 249, 115, 22;
				--dark-bg: 15, 23, 42;
			}
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 2em 1em;
			}
			.page-header {
				margin-bottom: 2rem;
				border-bottom: 1px solid rgba(var(--accent-amber), 0.3);
				padding-bottom: 1.5rem;
			}
			.page-header h1 {
				font-size: 2rem;
				margin: 0 0 0.3rem;
				background: linear-gradient(135deg, rgb(var(--accent-amber)), rgb(var(--accent-orange)));
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}
			.page-header p {
				color: rgba(var(--dark-bg), 0.6);
				margin: 0;
				font-size: 0.95rem;
			}
			.posts-list {
				display: flex;
				flex-direction: column;
				gap: 2rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-card {
				display: grid;
				grid-template-columns: 280px 1fr;
				gap: 1.5rem;
				background: rgba(var(--dark-bg), 0.02);
				border: 1px solid rgba(var(--accent-amber), 0.15);
				border-radius: 12px;
				overflow: hidden;
				transition: all 0.2s;
				text-decoration: none;
				color: inherit;
			}
			.post-card:hover {
				border-color: rgba(var(--accent-amber), 0.5);
				box-shadow: 0 4px 20px rgba(var(--accent-amber), 0.1);
				transform: translateY(-2px);
			}
			.post-card img {
				width: 100%;
				height: 180px;
				object-fit: cover;
				display: block;
			}
			.post-card-placeholder {
				width: 100%;
				height: 180px;
				background: linear-gradient(135deg, rgba(var(--accent-amber), 0.1), rgba(var(--accent-orange), 0.1));
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 3rem;
			}
			.post-card-body {
				padding: 1.2rem 1.2rem 1.2rem 0;
				display: flex;
				flex-direction: column;
				justify-content: center;
				gap: 0.5rem;
			}
			.post-meta {
				display: flex;
				align-items: center;
				gap: 0.6rem;
				font-size: 0.85rem;
			}
			.post-category {
				background: rgba(var(--accent-amber), 0.15);
				border: 1px solid rgba(var(--accent-amber), 0.4);
				color: rgb(var(--accent-orange));
				padding: 0.15em 0.6em;
				border-radius: 4px;
				font-weight: 600;
			}
			.post-date {
				color: rgba(var(--dark-bg), 0.5);
			}
			.post-title {
				font-size: 1.2rem;
				font-weight: 700;
				margin: 0;
				line-height: 1.4;
				color: rgb(var(--dark-bg));
			}
			.post-desc {
				font-size: 0.9rem;
				color: rgba(var(--dark-bg), 0.65);
				margin: 0;
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.post-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				margin-top: 0.2rem;
			}
			.post-tag {
				font-size: 0.75rem;
				padding: 0.1em 0.5em;
				background: rgba(var(--accent-cyan), 0.08);
				border: 1px solid rgba(var(--accent-cyan), 0.25);
				border-radius: 10px;
				color: rgb(var(--accent-cyan));
			}
			.empty {
				text-align: center;
				padding: 4rem;
				color: rgba(var(--dark-bg), 0.4);
			}
			@media (max-width: 720px) {
				.post-card {
					grid-template-columns: 1fr;
				}
				.post-card img,
				.post-card-placeholder {
					height: 200px;
				}
				.post-card-body {
					padding: 1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>My Notes</h1>
				<p>Jason 的亲历记录 — 硬件折腾、AI 研究、产品发布、经验与教训</p>
			</div>

			{posts.length === 0 ? (
				<div class="empty">暂无文章</div>
			) : (
				<ul class="posts-list">
					{posts.map(post => (
						<li>
							<a class="post-card" href={`/my/${post.id}/`}>
								{post.data.heroImage ? (
									<Image
										src={post.data.heroImage}
										alt={post.data.title}
										width={280}
										height={180}
									/>
								) : (
									<div class="post-card-placeholder">
										{categoryIcons[post.data.category] || '📝'}
									</div>
								)}
								<div class="post-card-body">
									<div class="post-meta">
										<span class="post-category">
											{categoryIcons[post.data.category]} {post.data.category}
										</span>
										<span class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</span>
									</div>
									<h2 class="post-title">{post.data.title}</h2>
									<p class="post-desc">{post.data.description}</p>
									{post.data.tags.length > 0 && (
										<div class="post-tags">
											{post.data.tags.map(tag => (
												<span class="post-tag">#{tag}</span>
											))}
										</div>
									)}
								</div>
							</a>
						</li>
					))}
				</ul>
			)}
		</main>
		<Footer />
	</body>
</html>

---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// 统计所有标签
const tagCounts = new Map<string, number>();
posts.forEach(post => {
	post.data.tags?.forEach(tag => {
		tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
	});
});

// 按文章数排序
const sortedTags = Array.from(tagCounts.entries()).sort((a, b) => b[1] - a[1]);

// 分类列表
const categories = ['Tech-Experiment', 'Progress-Report', 'Research', 'Tech-News', 'Other'];
const categoryIcons: Record<string, string> = {
	'Tech-Experiment': '🔬',
	'Progress-Report': '📊',
	'Research': '🔍',
	'Tech-News': '🚀',
	'Other': '📝',
};

// 客户端筛选需要的数据
const postsData = posts.map(post => ({
	id: post.id,
	title: post.data.title,
	category: post.data.category || 'Other',
	pubDate: post.data.pubDate,
	heroImage: post.data.heroImage,
	tags: post.data.tags || [],
}));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			:root {
				--accent-cyan: 0, 212, 255;
				--accent-purple: 157, 78, 221;
				--accent-mint: 72, 191, 145;
				--dark-bg: 15, 23, 42;
			}
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 2em 1em;
			}
			/* 分类筛选栏 - 绿色科技感 */
			.filter-bar {
				display: flex;
				flex-wrap: wrap;
				gap: 0.8em;
				margin-bottom: 1.5em;
				padding-bottom: 1em;
				border-bottom: 1px solid rgba(var(--accent-mint), 0.3);
			}
			.filter-item {
				display: inline-flex;
				align-items: center;
				gap: 0.3em;
				padding: 0.4em 0.8em;
				background: rgba(var(--accent-mint), 0.1);
				border: 1px solid rgba(var(--accent-mint), 0.4);
				border-radius: 20px;
				text-decoration: none;
				color: rgb(var(--accent-mint));
				font-size: 0.9em;
				font-weight: 500;
				transition: all 0.2s;
			}
			.filter-item:hover,
			.filter-item.active {
				background: rgba(var(--accent-mint), 0.2);
				border-color: rgb(var(--accent-mint));
				box-shadow: 0 0 10px rgba(var(--accent-mint), 0.4);
				transform: translateY(-1px);
			}
			/* 标签行 - 放在标题下方了 */
			.tags-bar {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				margin-top: 0.5em;
			}
			.tag-link {
				display: inline-block;
				padding: 0.15em 0.6em;
				background: rgba(var(--accent-purple), 0.1);
				border: 1px solid rgba(var(--accent-purple), 0.3);
				color: rgb(var(--accent-purple));
				border-radius: 12px;
				text-decoration: none;
				font-size: 0.8em;
				transition: all 0.2s;
			}
			.tag-link:hover {
				background: rgba(var(--accent-purple), 0.2);
				border-color: rgb(var(--accent-purple));
				box-shadow: 0 0 8px rgba(var(--accent-purple), 0.4);
			}
			/* 文章列表 */
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.2;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.meta-row {
				display: flex;
				align-items: center;
				gap: 0.5em;
				margin-bottom: 0.4em;
				font-size: 0.85em;
			}
			.category-small {
				background: rgba(var(--accent-mint), 0.15);
				border: 1px solid rgba(var(--accent-mint), 0.4);
				color: rgb(var(--accent-mint));
				padding: 0.1em 0.5em;
				border-radius: 4px;
				font-weight: 500;
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent-cyan));
			}
			ul a:hover img {
				box-shadow: 0 4px 20px rgba(var(--accent-cyan), 0.2);
			}
			.empty-state {
				text-align: center;
				padding: 3em;
				color: rgb(var(--gray));
			}
			@media (max-width: 720px) {
				.filter-bar {
					gap: 0.5em;
				}
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- 分类筛选 -->
			<div class="filter-bar">
				<a href="/blog/" class="filter-item" data-filter="all">All</a>
				{categories.map(cat => (
					<a href={`/blog/?category=${cat}`} class="filter-item" data-filter={cat}>
						<span>{categoryIcons[cat]}</span>
						<span>{cat}</span>
					</a>
				))}
			</div>

			<section>
				<div id="empty-state" class="empty-state" style="display: none;">
					<p>No posts in this category.</p>
				</div>
				<ul id="posts-list">
					{posts.map((post, index) => (
						<li data-category={post.data.category || 'Other'} data-index={index} class={index >= 12 ? 'hidden-post' : ''}>
							<a href={`/blog/${post.id}/`}>
								{post.data.heroImage && (
									<Image width={720} height={360} src={post.data.heroImage} alt="" />
								)}
								<div class="meta-row">
									<span class="category-small">{post.data.category}</span>
									<span class="date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</div>
								<h4 class="title">{post.data.title}</h4>
								<div class="tags-bar">
									{post.data.tags?.map(tag => (
										<span class="tag-link">#{tag}</span>
									))}
								</div>
							</a>
						</li>
					))}
				</ul>
				<div id="load-more" class="load-more" style="display: none;">
					<button onclick="loadMore()">加载更多 ↓</button>
				</div>
			</section>

			<style>
				.hidden-post {
					display: none !important;
				}
				.load-more {
					text-align: center;
					padding: 2em 0;
				}
				.load-more button {
					padding: 0.8em 2em;
					background: rgba(var(--accent-mint), 0.1);
					border: 1px solid rgba(var(--accent-mint), 0.4);
					border-radius: 24px;
					color: rgb(var(--accent-mint));
					font-size: 1em;
					cursor: pointer;
					transition: all 0.2s;
				}
				.load-more button:hover {
					background: rgba(var(--accent-mint), 0.2);
					box-shadow: 0 0 15px rgba(var(--accent-mint), 0.4);
				}
			</style>

			<script>
				// 无限滚动配置
				const CONFIG = {
					initialLoad: 12,      // 首屏加载数量
					loadPerBatch: 6,      // 每次加载数量
				};
				
				// 加载更多文章
				function loadMore() {
					const postsList = document.getElementById('posts-list');
					const hiddenPosts = postsList.querySelectorAll('li.hidden-post');
					const postsToShow = Math.min(CONFIG.loadPerBatch, hiddenPosts.length);
					
					for (let i = 0; i < postsToShow; i++) {
						hiddenPosts[i].classList.remove('hidden-post');
					}
					
					updateLoadMoreButton();
				}
				
				// 更新"加载更多"按钮状态
				function updateLoadMoreButton() {
					const postsList = document.getElementById('posts-list');
					const loadMoreBtn = document.getElementById('load-more');
					const selectedCategory = new URL(window.location.href).searchParams.get('category');
					
					// 计算当前分类下还有多少隐藏文章
					let hiddenCount = 0;
					postsList.querySelectorAll('li.hidden-post').forEach(post => {
						const category = post.getAttribute('data-category') || 'Other';
						if (!selectedCategory || category === selectedCategory) {
							hiddenCount++;
						}
					});
					
					if (hiddenCount > 0) {
						loadMoreBtn.style.display = '';
						loadMoreBtn.querySelector('button').textContent = `加载更多 (${hiddenCount}) ↓`;
					} else {
						loadMoreBtn.style.display = 'none';
					}
				}
				
				// 分类筛选
				function filterPosts() {
					const url = new URL(window.location.href);
					const selectedCategory = url.searchParams.get('category');
					
					// 更新 active 状态
					document.querySelectorAll('.filter-item').forEach(item => {
						item.classList.remove('active');
						const filter = item.getAttribute('data-filter');
						if ((!selectedCategory && filter === 'all') || selectedCategory === filter) {
							item.classList.add('active');
						}
					});
					
					// 筛选文章
					const postsList = document.getElementById('posts-list');
					const emptyState = document.getElementById('empty-state');
					const allPosts = postsList.querySelectorAll('li');
					let visibleCount = 0;
					let shownCount = 0;
					
					allPosts.forEach(post => {
						const category = post.getAttribute('data-category') || 'Other';
						const matchesCategory = !selectedCategory || category === selectedCategory;
						
						if (matchesCategory) {
							visibleCount++;
							// 只显示前 N 篇
							if (shownCount < CONFIG.initialLoad) {
								post.classList.remove('hidden-post');
								shownCount++;
							} else {
								post.classList.add('hidden-post');
							}
						} else {
							post.classList.add('hidden-post');
						}
					});
					
					// 显示/隐藏空状态
					if (visibleCount === 0) {
						postsList.style.display = 'none';
						emptyState.style.display = '';
						document.getElementById('load-more').style.display = 'none';
					} else {
						postsList.style.display = '';
						emptyState.style.display = 'none';
						updateLoadMoreButton();
					}
				}
				
				// 页面加载时执行
				filterPosts();
				
				// 监听 URL 变化（浏览器前进后退）
				window.addEventListener('popstate', filterPosts);
			</script>
		</main>
		<Footer />
	</body>
</html>

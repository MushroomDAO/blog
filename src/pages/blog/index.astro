---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// 获取最近3天的文章作为轮播项
const now = new Date();
const threeDaysAgo = new Date(now.getTime() - 3 * 24 * 60 * 60 * 1000);
const carouselPosts = posts.filter(post => {
	const postDate = new Date(post.data.pubDate);
	return postDate >= threeDaysAgo;
}).slice(0, 5); // 最多5篇

// 轮播之后剩余的文章（用于列表展示）
const listPosts = posts.filter(post => 
	!carouselPosts.find(cp => cp.id === post.id)
);

// 统计所有标签
const tagCounts = new Map<string, number>();
posts.forEach(post => {
	post.data.tags?.forEach(tag => {
		tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
	});
});

// 按文章数排序
const sortedTags = Array.from(tagCounts.entries()).sort((a, b) => b[1] - a[1]);

// 分类列表
const categories = ['Tech-Experiment', 'Progress-Report', 'Research', 'Tech-News', 'Other'];
const categoryIcons: Record<string, string> = {
	'Tech-Experiment': '🔬',
	'Progress-Report': '📊',
	'Research': '🔍',
	'Tech-News': '🚀',
	'Other': '📝',
};

// 客户端筛选需要的数据
const postsData = posts.map(post => ({
	id: post.id,
	title: post.data.title,
	category: post.data.category || 'Other',
	pubDate: post.data.pubDate,
	heroImage: post.data.heroImage,
	tags: post.data.tags || [],
}));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			:root {
				--accent-cyan: 0, 212, 255;
				--accent-purple: 157, 78, 221;
				--accent-mint: 72, 191, 145;
				--dark-bg: 15, 23, 42;
			}
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 2em 1em;
			}
			/* 分类筛选栏 - 绿色科技感 */
			.filter-bar {
				display: flex;
				flex-wrap: wrap;
				gap: 0.8em;
				margin-bottom: 1.5em;
				padding-bottom: 1em;
				border-bottom: 1px solid rgba(var(--accent-mint), 0.3);
			}
			.filter-item {
				display: inline-flex;
				align-items: center;
				gap: 0.3em;
				padding: 0.4em 0.8em;
				background: rgba(var(--accent-mint), 0.1);
				border: 1px solid rgba(var(--accent-mint), 0.4);
				border-radius: 20px;
				text-decoration: none;
				color: rgb(var(--accent-mint));
				font-size: 0.9em;
				font-weight: 500;
				transition: all 0.2s;
			}
			.filter-item:hover,
			.filter-item.active {
				background: rgba(var(--accent-mint), 0.2);
				border-color: rgb(var(--accent-mint));
				box-shadow: 0 0 10px rgba(var(--accent-mint), 0.4);
				transform: translateY(-1px);
			}
			/* ===== 轮播 Banner ===== */
			.carousel-banner {
				position: relative;
				width: 100%;
				margin-bottom: 2rem;
				border-radius: 16px;
				overflow: hidden;
				background: rgba(var(--dark-bg), 0.5);
				border: 1px solid rgba(var(--accent-mint), 0.2);
			}
			.carousel-container {
				display: flex;
				transition: transform 0.5s ease-in-out;
			}
			.carousel-slide {
				min-width: 100%;
				flex-shrink: 0;
			}
			.carousel-slide a {
				display: block;
				text-decoration: none;
			}
			.carousel-image {
				width: 100%;
				height: 400px;
				object-fit: cover;
				display: block;
			}
			.carousel-content {
				padding: 1.5rem;
				background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.6) 50%, transparent 100%);
				position: absolute;
				bottom: 0;
				left: 0;
				right: 0;
				color: white;
			}
			.carousel-meta {
				display: flex;
				align-items: center;
				gap: 0.8em;
				margin-bottom: 0.5rem;
				font-size: 0.85em;
			}
			.carousel-category {
				background: rgba(var(--accent-mint), 0.3);
				border: 1px solid rgba(var(--accent-mint), 0.6);
				color: rgb(var(--accent-mint));
				padding: 0.2em 0.6em;
				border-radius: 4px;
				font-weight: 500;
			}
			.carousel-date {
				color: rgba(255, 255, 255, 0.7);
			}
			.carousel-title {
				font-size: 1.8rem;
				font-weight: 700;
				margin: 0;
				line-height: 1.3;
				color: white;
				text-shadow: 0 2px 4px rgba(0,0,0,0.5);
			}
			.carousel-nav {
				position: absolute;
				top: 50%;
				transform: translateY(-50%);
				width: 44px;
				height: 44px;
				background: rgba(0, 0, 0, 0.5);
				border: 1px solid rgba(var(--accent-mint), 0.4);
				border-radius: 50%;
				cursor: pointer;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 1.2rem;
				color: rgb(var(--accent-mint));
				transition: all 0.3s;
				z-index: 10;
			}
			.carousel-nav:hover {
				background: rgba(var(--accent-mint), 0.3);
				box-shadow: 0 0 15px rgba(var(--accent-mint), 0.5);
			}
			.carousel-nav.prev {
				left: 1rem;
			}
			.carousel-nav.next {
				right: 1rem;
			}
			.carousel-dots {
				display: flex;
				justify-content: center;
				gap: 0.5rem;
				padding: 1rem;
				background: rgba(0, 0, 0, 0.3);
			}
			.carousel-dot {
				width: 10px;
				height: 10px;
				border-radius: 50%;
				background: rgba(255, 255, 255, 0.3);
				cursor: pointer;
				transition: all 0.3s;
				border: none;
				padding: 0;
			}
			.carousel-dot.active {
				background: rgb(var(--accent-mint));
				box-shadow: 0 0 10px rgba(var(--accent-mint), 0.8);
			}
			.carousel-dot:hover {
				background: rgba(var(--accent-mint), 0.7);
			}
			/* 标签行 */
			.tags-bar {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				margin-top: 0.5em;
			}
			.tag-link {
				display: inline-block;
				padding: 0.15em 0.6em;
				background: rgba(var(--accent-purple), 0.1);
				border: 1px solid rgba(var(--accent-purple), 0.3);
				color: rgb(var(--accent-purple));
				border-radius: 12px;
				text-decoration: none;
				font-size: 0.8em;
				transition: all 0.2s;
			}
			.tag-link:hover {
				background: rgba(var(--accent-purple), 0.2);
				border-color: rgb(var(--accent-purple));
				box-shadow: 0 0 8px rgba(var(--accent-purple), 0.4);
			}
			/* 文章列表 */
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li img {
				width: 100%;
				height: 200px;
				object-fit: cover;
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.2;
				font-size: 1.1rem;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.meta-row {
				display: flex;
				align-items: center;
				gap: 0.5em;
				margin-bottom: 0.4em;
				font-size: 0.85em;
			}
			.category-small {
				background: rgba(var(--accent-mint), 0.15);
				border: 1px solid rgba(var(--accent-mint), 0.4);
				color: rgb(var(--accent-mint));
				padding: 0.1em 0.5em;
				border-radius: 4px;
				font-weight: 500;
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent-cyan));
			}
			ul a:hover img {
				box-shadow: 0 4px 20px rgba(var(--accent-cyan), 0.2);
			}
			.empty-state {
				text-align: center;
				padding: 3em;
				color: rgb(var(--gray));
			}
			@media (max-width: 720px) {
				.filter-bar {
					gap: 0.5em;
				}
				.carousel-image {
					height: 250px;
				}
				.carousel-title {
					font-size: 1.2rem;
				}
				.carousel-content {
					padding: 1rem;
				}
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li img {
					height: 180px;
				}
			}
			.hidden-post {
				display: none !important;
			}
			.load-more {
				text-align: center;
				padding: 2em 0;
			}
			.load-more button {
				padding: 0.8em 2em;
				background: rgba(var(--accent-mint), 0.1);
				border: 1px solid rgba(var(--accent-mint), 0.4);
				border-radius: 24px;
				color: rgb(var(--accent-mint));
				font-size: 1em;
				cursor: pointer;
				transition: all 0.2s;
			}
			.load-more button:hover {
				background: rgba(var(--accent-mint), 0.2);
				box-shadow: 0 0 15px rgba(var(--accent-mint), 0.4);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- 分类筛选 -->
			<div class="filter-bar">
				<a href="/blog/" class="filter-item" data-filter="all">All</a>
				{categories.map(cat => (
					<a href={`/blog/?category=${cat}`} class="filter-item" data-filter={cat}>
						<span>{categoryIcons[cat]}</span>
						<span>{cat}</span>
					</a>
				))}
			</div>

			{carouselPosts.length > 0 && (
				<div class="carousel-banner" id="carousel">
					<div class="carousel-container" id="carouselContainer">
						{carouselPosts.map((post, index) => (
							<div class="carousel-slide" data-index={index}>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage ? (
										<Image 
											src={post.data.heroImage} 
											alt={post.data.title}
											width={960}
											height={400}
											class="carousel-image"
										/>
									) : (
										<div class="carousel-image" style="background: linear-gradient(135deg, rgba(var(--accent-mint), 0.2), rgba(var(--accent-purple), 0.2)); display: flex; align-items: center; justify-content: center;">
											<span style="font-size: 3rem; opacity: 0.5;">📝</span>
										</div>
									)}
									<div class="carousel-content">
										<div class="carousel-meta">
											<span class="carousel-category">{post.data.category}</span>
											<span class="carousel-date">
												<FormattedDate date={post.data.pubDate} />
											</span>
										</div>
										<h2 class="carousel-title">{post.data.title}</h2>
									</div>
								</a>
							</div>
						))}
					</div>
					
					{carouselPosts.length > 1 && (
						<>
							<button class="carousel-nav prev" id="carouselPrev" aria-label="Previous">‹</button>
							<button class="carousel-nav next" id="carouselNext" aria-label="Next">›</button>
							<div class="carousel-dots" id="carouselDots">
								{carouselPosts.map((_, index) => (
									<button class={`carousel-dot ${index === 0 ? 'active' : ''}`} data-index={index} aria-label={`Go to slide ${index + 1}`}></button>
								))}
							</div>
						</>
					)}
				</div>
			)}

			<section>
				<div id="empty-state" class="empty-state" style="display: none;">
					<p>No posts in this category.</p>
				</div>
				<ul id="posts-list">
					{listPosts.map((post, index) => (
						<li data-category={post.data.category || 'Other'} data-index={index} class={index >= 12 ? 'hidden-post' : ''}>
							<a href={`/blog/${post.id}/`}>
								{post.data.heroImage && (
									<Image width={720} height={360} src={post.data.heroImage} alt="" />
								)}
								<div class="meta-row">
									<span class="category-small">{post.data.category}</span>
									<span class="date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</div>
								<h4 class="title">{post.data.title}</h4>
								<div class="tags-bar">
									{post.data.tags?.map(tag => (
										<span class="tag-link">#{tag}</span>
									))}
								</div>
							</a>
						</li>
					))}
				</ul>
				<div id="load-more" class="load-more" style="display: none;">
					<button onclick="loadMore()">加载更多 ↓</button>
				</div>
			</section>

			<script>
				// 轮播功能
				(function() {
					const carousel = document.getElementById('carousel');
					if (!carousel) return;
					
					const container = document.getElementById('carouselContainer');
					const prevBtn = document.getElementById('carouselPrev');
					const nextBtn = document.getElementById('carouselNext');
					const dots = document.querySelectorAll('.carousel-dot');
					const slides = document.querySelectorAll('.carousel-slide');
					
					if (slides.length <= 1) return;
					
					let currentIndex = 0;
					let autoplayInterval;
					
					function goToSlide(index) {
						if (index < 0) index = slides.length - 1;
						if (index >= slides.length) index = 0;
						
						currentIndex = index;
						container.style.transform = `translateX(-${currentIndex * 100}%)`;
						
						dots.forEach((dot, i) => {
							dot.classList.toggle('active', i === currentIndex);
						});
					}
					
					function nextSlide() {
						goToSlide(currentIndex + 1);
					}
					
					function prevSlide() {
						goToSlide(currentIndex - 1);
					}
					
					function startAutoplay() {
						autoplayInterval = setInterval(nextSlide, 5000);
					}
					
					function stopAutoplay() {
						clearInterval(autoplayInterval);
					}
					
					// 事件监听
					if (prevBtn) prevBtn.addEventListener('click', () => {
						prevSlide();
						stopAutoplay();
						startAutoplay();
					});
					
					if (nextBtn) nextBtn.addEventListener('click', () => {
						nextSlide();
						stopAutoplay();
						startAutoplay();
					});
					
					dots.forEach((dot, index) => {
						dot.addEventListener('click', () => {
							goToSlide(index);
							stopAutoplay();
							startAutoplay();
						});
					});
					
					// 鼠标悬停暂停
					carousel.addEventListener('mouseenter', stopAutoplay);
					carousel.addEventListener('mouseleave', startAutoplay);
					
					// 触摸滑动支持
					let touchStartX = 0;
					let touchEndX = 0;
					
					carousel.addEventListener('touchstart', (e) => {
						touchStartX = e.changedTouches[0].screenX;
						stopAutoplay();
					}, { passive: true });
					
					carousel.addEventListener('touchend', (e) => {
						touchEndX = e.changedTouches[0].screenX;
						if (touchStartX - touchEndX > 50) {
							nextSlide();
						} else if (touchEndX - touchStartX > 50) {
							prevSlide();
						}
						startAutoplay();
					}, { passive: true });
					
					// 自动播放
					startAutoplay();
				})();
			
				// 无限滚动配置
				const CONFIG = {
					initialLoad: 12,
					loadPerBatch: 6,
				};
				
				function loadMore() {
					const postsList = document.getElementById('posts-list');
					const selectedCategory = new URL(window.location.href).searchParams.get('category');
					
					const allHiddenPosts = Array.from(postsList.querySelectorAll('li.hidden-post'));
					const hiddenPosts = allHiddenPosts.filter(post => {
						const category = post.getAttribute('data-category') || 'Other';
						return !selectedCategory || category === selectedCategory;
					});
					
					const postsToShow = Math.min(CONFIG.loadPerBatch, hiddenPosts.length);
					
					for (let i = 0; i < postsToShow; i++) {
						hiddenPosts[i].classList.remove('hidden-post');
					}
					
					updateLoadMoreButton();
				}
				
				window.loadMore = loadMore;
				
				function updateLoadMoreButton() {
					const postsList = document.getElementById('posts-list');
					const loadMoreBtn = document.getElementById('load-more');
					const selectedCategory = new URL(window.location.href).searchParams.get('category');
					
					let hiddenCount = 0;
					postsList.querySelectorAll('li.hidden-post').forEach(post => {
						const category = post.getAttribute('data-category') || 'Other';
						if (!selectedCategory || category === selectedCategory) {
							hiddenCount++;
						}
					});
					
					if (hiddenCount > 0) {
						loadMoreBtn.style.display = '';
						loadMoreBtn.querySelector('button').textContent = `加载更多 (${hiddenCount}) ↓`;
					} else {
						loadMoreBtn.style.display = 'none';
					}
				}
				
				function filterPosts() {
					const url = new URL(window.location.href);
					const selectedCategory = url.searchParams.get('category');
					
					document.querySelectorAll('.filter-item').forEach(item => {
						item.classList.remove('active');
						const filter = item.getAttribute('data-filter');
						if ((!selectedCategory && filter === 'all') || selectedCategory === filter) {
							item.classList.add('active');
						}
					});
					
					const postsList = document.getElementById('posts-list');
					const emptyState = document.getElementById('empty-state');
					const allPosts = postsList.querySelectorAll('li');
					let visibleCount = 0;
					let shownCount = 0;
					
					allPosts.forEach(post => {
						const category = post.getAttribute('data-category') || 'Other';
						const matchesCategory = !selectedCategory || category === selectedCategory;
						
						if (matchesCategory) {
							visibleCount++;
							if (shownCount < CONFIG.initialLoad) {
								post.classList.remove('hidden-post');
								shownCount++;
							} else {
								post.classList.add('hidden-post');
							}
						} else {
							post.classList.add('hidden-post');
						}
					});
					
					if (visibleCount === 0) {
						postsList.style.display = 'none';
						emptyState.style.display = '';
						document.getElementById('load-more').style.display = 'none';
					} else {
						postsList.style.display = '';
						emptyState.style.display = 'none';
						updateLoadMoreButton();
					}
				}
				
				filterPosts();
				window.addEventListener('popstate', filterPosts);
			</script>
		</main>
		<Footer />
	</body>
</html>

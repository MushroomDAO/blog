# ============================================================
# 小宝宝公众号发布配置
# 复制此文件为 .env，填入实际值后生效
# ============================================================

BLOG_USER=xiaobaobao

# ---------------- 小宝宝的微信公众号配置 ----------------
# 从 https://mp.weixin.qq.com -> 设置与开发 -> 基本配置 获取
WECHAT_APP_ID_XBB=wx_填入AppID
WECHAT_APP_SECRET_XBB=填入AppSecret
WECHAT_MP_ID_XBB=gh_填入原始ID

# ---------------- 小红书配置（后续开通后填）----------------
XHS_MCP_URL=http://localhost:3456
